// Dev.xcconfig
// Ambiente de desenvolvimento local — por padrão aponta para a instância demo do trabalho

PRODUCT_BUNDLE_IDENTIFIER = com.bradesco.mobile.app.dev
BUNDLE_DISPLAY_NAME = Bradesco Dev
URL_SCHEME = bradesco-app-dev

APS_ENVIRONMENT = development

// ServiceNow demo default
SERVICENOW_INSTANCE_URL = https:/$()/demoalectriallwfzbblp136802.service-now.com
SERVICENOW_PINNED_HOST = service-now-demo-pin-disabled.local
SERVICENOW_OIDC_CLIENT_ID = REPLACE_DEMO_CLIENT_ID

// Railway aux services (dev environment)
RAILWAY_BFF_FLAGS_URL = https:/$()/bff-flags-dev.up.railway.app
RAILWAY_OTEL_COLLECTOR_URL = https:/$()/otel-dev.up.railway.app

// IdP dev / staging compartilhado
IDP_AUTHORIZATION_ENDPOINT = https:/$()/idp-dev.bradesco.com.br/oauth/authorize
IDP_TOKEN_ENDPOINT = https:/$()/idp-dev.bradesco.com.br/oauth/token
IDP_END_SESSION_ENDPOINT = https:/$()/idp-dev.bradesco.com.br/oauth/logout

PROVISIONING_PROFILE_SPECIFIER = match Development com.bradesco.mobile.app.dev
