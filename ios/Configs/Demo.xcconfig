// Demo.xcconfig
// Ambiente de demos comerciais — instância demo SN com dados seed
#include "Base.xcconfig"

PRODUCT_BUNDLE_IDENTIFIER = com.bradesco.mobile.app.demo
BUNDLE_DISPLAY_NAME = Bradesco Demo
URL_SCHEME = bradesco-app-demo

APS_ENVIRONMENT = production

SERVICENOW_INSTANCE_URL = https:/$()/demoalectriallwfzbblp136802.service-now.com
// Demo usa o certificado público da instância ServiceNow. Produção deve configurar SPKI real.
SERVICENOW_PINNED_HOST = service-now-demo-pin-disabled.local
SERVICENOW_OIDC_CLIENT_ID = REPLACE_DEMO_CLIENT_ID

RAILWAY_BFF_FLAGS_URL = https:/$()/bff-flags-demo.up.railway.app
RAILWAY_OTEL_COLLECTOR_URL = https:/$()/otel-demo.up.railway.app

// Demo usa IdP mock para evitar dependência de prod
IDP_AUTHORIZATION_ENDPOINT = https:/$()/idp-demo.up.railway.app/oauth/authorize
IDP_TOKEN_ENDPOINT = https:/$()/idp-demo.up.railway.app/oauth/token
IDP_END_SESSION_ENDPOINT = https:/$()/idp-demo.up.railway.app/oauth/logout

PROVISIONING_PROFILE_SPECIFIER = match AppStore com.bradesco.mobile.app.demo
